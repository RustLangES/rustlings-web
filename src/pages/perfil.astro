---
import { tracks } from "~/const/tracks"
import Layout from "~/layouts/Layout.astro"
import { getUserProgress } from "~/lib/progress-db"
import IconLeft from "~icons/tabler/arrow-big-left-lines-filled"
import IconCertificate from "~icons/tabler/certificate"
import IconDownload from "~icons/tabler/download"
import IconLink from "~icons/tabler/link"
import IconLogout from "~icons/tabler/logout"

if (!Astro.locals.user) {
	return Astro.redirect("/login")
}

const user = Astro.locals.user
const { DB } = Astro.locals.runtime.env

const [fullNameRow, certsResult, progress] = await Promise.all([
	DB.prepare("SELECT full_name FROM users WHERE id = ?").bind(user.id).first<{ full_name: string | null }>(),
	DB.prepare(
		"SELECT id, course_id, name_used, issued_at FROM user_certificates WHERE user_id = ? ORDER BY issued_at DESC",
	)
		.bind(user.id)
		.all<{ id: string; course_id: string; name_used: string; issued_at: string }>(),
	getUserProgress(DB, user.id),
])

const fullName = fullNameRow?.full_name ?? ""
const certificates = certsResult.results

const trackMap = Object.fromEntries(tracks.map((t) => [t.id, t]))
---

<Layout title="Mi perfil — Rustlings Web">
  <header class="p-2 w-full shrink-0">
    <nav class="relative z-50 flex items-center justify-between px-3 py-1 border border-stroke-color backdrop-blur-md bg-bg-nav rounded-md shadow-lg">
      <a
        href="/aprender"
        class="flex items-center gap-2 px-3 py-1.5 text-sm font-medium text-secondary/60 border border-transparent rounded-lg hover:border-yellow hover:text-yellow transition-all duration-300"
      >
        <IconLeft font-size={20} />
        Temario
      </a>
      <a
        href="/api/auth/logout"
        data-astro-reload
        class="flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-secondary/50 border border-transparent rounded-lg hover:border-red-500/40 hover:text-red-400 transition-all duration-300"
      >
        <IconLogout font-size={16} />
        Cerrar sesión
      </a>
    </nav>
  </header>

  <main class="flex-1 flex flex-col items-center px-4 py-10 gap-8">
    <div class="w-full max-w-xl flex flex-col gap-6">

      <!-- User info card -->
      <section class="bg-light-bg border border-stroke-color rounded-2xl p-6 flex flex-col gap-5">
        <div class="flex flex-col gap-0.5">
          <h1 class="text-lg font-bold text-secondary">Mi perfil</h1>
          <p class="text-xs text-secondary/40">{user.email}</p>
        </div>

        <div class="flex flex-col gap-4">
          <div class="flex flex-col gap-1.5">
            <label class="text-xs text-secondary/60 font-medium" for="username">Usuario</label>
            <input
              id="username"
              type="text"
              value={user.username ?? ""}
              disabled
              class="bg-primary border border-stroke-color/50 rounded-lg px-4 py-2.5 text-sm text-secondary/40 cursor-not-allowed"
            />
          </div>

          <div class="flex flex-col gap-1.5">
            <label class="text-xs text-secondary/60 font-medium" for="full-name">Nombre completo</label>
            <input
              id="full-name"
              type="text"
              value={fullName}
              maxlength="80"
              placeholder="Tu nombre completo"
              class="bg-primary border border-stroke-color rounded-lg px-4 py-2.5 text-sm text-secondary placeholder-secondary/30 focus:outline-none focus:border-yellow/50 transition-colors"
            />
          </div>

          <div id="profile-error" class="hidden text-red-400 text-sm"></div>
          <div id="profile-success" class="hidden text-green-400 text-sm">Cambios guardados.</div>

          <button
            id="save-profile"
            type="button"
            class="self-start px-5 py-2 bg-yellow text-primary text-sm font-bold rounded-lg hover:opacity-90 transition-opacity"
          >
            Guardar cambios
          </button>
        </div>
      </section>

      <!-- Certificates section -->
      <section class="flex flex-col gap-4">
        <h2 class="text-base font-bold text-secondary flex items-center gap-2">
          <IconCertificate font-size={18} class="text-yellow" />
          Mis certificados
        </h2>

        {certificates.length === 0 ? (
          <div class="bg-light-bg border border-stroke-color rounded-2xl p-6 text-center">
            <p class="text-secondary/40 text-sm">Aún no tienes certificados.</p>
            <p class="text-secondary/30 text-xs mt-1">Completa todos los ejercicios de un curso para obtener uno.</p>
          </div>
        ) : (
          <div class="flex flex-col gap-3">
            {certificates.map((cert) => {
              const track = trackMap[cert.course_id]
              const issuedDate = new Date(cert.issued_at).toLocaleDateString("es-MX", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })
              return (
                <div class="bg-light-bg border border-stroke-color rounded-2xl p-5 flex items-center gap-4">
                  <div class="shrink-0 w-10 h-10 flex items-center justify-center rounded-xl bg-yellow/10 border border-yellow/20">
                    <IconCertificate font-size={20} class="text-yellow" />
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-semibold text-secondary truncate">
                      {track?.title ?? cert.course_id}
                    </p>
                    <p class="text-xs text-secondary/40 mt-0.5">
                      Expedido el {issuedDate} · A nombre de <span class="text-secondary/60">{cert.name_used}</span>
                    </p>
                  </div>
                  <div class="shrink-0 flex items-center gap-2">
                    <button
                      data-copy-link={`/verificar/${cert.id}`}
                      class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold text-secondary/60 border border-stroke-color rounded-lg hover:border-yellow hover:text-yellow transition-all"
                      title="Copiar enlace de verificación"
                    >
                      <IconLink font-size={14} />
                      <span class="copy-label">Compartir</span>
                    </button>
                    <a
                      href={`/certificado/${cert.course_id}`}
                      class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold text-secondary/60 border border-stroke-color rounded-lg hover:border-yellow hover:text-yellow transition-all"
                    >
                      <IconDownload font-size={14} />
                      Descargar
                    </a>
                  </div>
                </div>
              )
            })}
          </div>
        )}

        <!-- Courses in progress without certificates -->
        {tracks.filter(t => !t.disabled && !certificates.find(c => c.course_id === t.id)).map(track => {
          const completed = (progress[track.id] ?? []).length
          const total = track.lessons
          const pct = total > 0 ? Math.round((completed / total) * 100) : 0
          const isComplete = pct === 100
          return (
            <div class={`bg-light-bg/50 border border-stroke-color/50 rounded-2xl p-5 flex items-center gap-4 ${isComplete ? "" : "opacity-60"}`}>
              <div class={`shrink-0 w-10 h-10 flex items-center justify-center rounded-xl ${isComplete ? "bg-yellow/10 border border-yellow/20" : "bg-stroke-color/30"}`}>
                <IconCertificate font-size={20} class={isComplete ? "text-yellow" : "text-secondary/30"} />
              </div>
              <div class="flex-1 min-w-0">
                <p class={`text-sm font-semibold truncate ${isComplete ? "text-secondary" : "text-secondary/60"}`}>{track.title}</p>
                <div class="flex items-center gap-2 mt-1">
                  <div class="flex-1 h-1 bg-stroke-color/30 rounded-full overflow-hidden max-w-32">
                    <div class={`h-full rounded-full ${isComplete ? "bg-yellow" : "bg-yellow/40"}`} style={`width:${pct}%`}></div>
                  </div>
                  <span class={`text-xs ${isComplete ? "text-yellow" : "text-secondary/30"}`}>{pct}% completado</span>
                </div>
              </div>
              {isComplete ? (
                <a
                  href={`/certificado/${track.id}`}
                  class="shrink-0 flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold text-black bg-yellow rounded-lg hover:opacity-80 transition-all"
                >
                  <IconCertificate font-size={14} />
                  Ver Certificado
                </a>
              ) : (
                <span class="shrink-0 text-xs text-secondary/30 px-3 py-1.5 border border-stroke-color/30 rounded-lg">
                  En progreso
                </span>
              )}
            </div>
          )
        })}
      </section>

    </div>
  </main>
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    document.getElementById("save-profile")?.addEventListener("click", async () => {
      const btn = document.getElementById("save-profile") as HTMLButtonElement
      const input = document.getElementById("full-name") as HTMLInputElement
      const errorEl = document.getElementById("profile-error")!
      const successEl = document.getElementById("profile-success")!

      btn.disabled = true
      btn.textContent = "Guardando..."
      errorEl.classList.add("hidden")
      successEl.classList.add("hidden")

      const res = await fetch("/api/auth/profile", {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ fullName: input.value }),
      })

      btn.disabled = false
      btn.textContent = "Guardar cambios"

      if (res.ok) {
        successEl.classList.remove("hidden")
        setTimeout(() => successEl.classList.add("hidden"), 3000)
      } else {
        const { error } = await res.json() as { error: string }
        errorEl.textContent = error
        errorEl.classList.remove("hidden")
      }
    })

    // Copy verification link
    document.querySelectorAll<HTMLButtonElement>("[data-copy-link]").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const path = btn.dataset.copyLink!
        const url = `${window.location.origin}${path}`
        await navigator.clipboard.writeText(url)
        const label = btn.querySelector(".copy-label")!
        const original = label.textContent
        label.textContent = "¡Copiado!"
        btn.classList.add("border-yellow", "text-yellow")
        setTimeout(() => {
          label.textContent = original
          btn.classList.remove("border-yellow", "text-yellow")
        }, 2000)
      })
    })
  })
</script>
