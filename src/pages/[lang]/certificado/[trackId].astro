---
import logoSvgUrl from "~/assets/Rust_Lang_ES_Logo_Blanco_color.svg?url"
import { tracks } from "~/const/tracks"
import { useTranslations } from "~/i18n/utils"
import Layout from "~/layouts/Layout.astro"
import IconLeft from "~icons/tabler/arrow-big-left-lines-filled"

export const prerender = true

export function getStaticPaths() {
	return tracks
		.filter((t) => !t.disabled && t.slugs.length > 0)
		.flatMap((t) => [
			{ params: { lang: "es", trackId: t.id }, props: { track: t } },
			{ params: { lang: "en", trackId: t.id }, props: { track: t } },
		])
}

const { track } = Astro.props
const lang = Astro.params.lang as "es" | "en"
const t = useTranslations(lang)
---

<Layout title={`${t("certificate.back_button")} — ${track.title}`}>
  <header class="p-2 w-full shrink-0">
    <nav class="relative z-50 flex items-center justify-between px-3 py-1 border border-stroke-color backdrop-blur-md bg-bg-nav rounded-md shadow-lg">
      <a
        href={`/${lang}/aprender`}
        class="flex items-center gap-2 px-3 py-1.5 text-sm font-medium text-secondary/60 border border-transparent rounded-lg hover:border-yellow hover:text-yellow transition-all duration-300"
      >
        <IconLeft font-size={20} />
        {t("certificate.back_button")}
      </a>
    </nav>
  </header>

  <main class="flex-1 flex flex-col items-center px-4 py-8">
    <div class="w-full max-w-6xl flex flex-col lg:flex-row gap-8 items-start">

      <!-- LEFT: Congrats + Name + Share -->
      <div class="w-full lg:w-72 shrink-0 flex flex-col gap-5">

        <div>
          <h1 class="text-2xl font-bold text-secondary">{t("certificate.your_certificate")}</h1>
          <p class="text-secondary/40 text-sm mt-0.5" id="cert-subtitle">{t("certificate.loading")}</p>
        </div>

        <!-- Congratulations (always visible — this page is only for the owner) -->
        <div class="rounded-2xl border border-yellow/20 bg-yellow/5 p-6 flex flex-col gap-3">
          <p class="text-yellow font-extrabold text-base leading-tight">{t("certificate.congratulations")}</p>
          <p class="text-secondary/70 text-xs leading-relaxed">
            {t("certificate.success_message_1")}
          </p>
          <p class="text-secondary/70 text-xs leading-relaxed">
            {t("certificate.success_message_2").replace("{trackTitle}", track.title)}
          </p>
          <p class="text-yellow/60 text-xs font-medium mt-1">
            {t("certificate.intro_text")}
          </p>
        </div>

        <!-- Name display for logged-in users -->
        <div id="cert-name-display" class="hidden flex-col gap-1">
          <p class="text-xs text-secondary/40 font-medium">{t("certificate.your_name")}</p>
          <p class="text-base font-bold text-secondary" id="cert-name-text"></p>
          <a href={`/${lang}/perfil`} class="inline-flex items-center gap-1 text-xs text-secondary/40 hover:text-yellow transition-colors mt-0.5">
            {t("certificate.edit_profile")} <span class="text-[10px]">→</span>
          </a>
        </div>

        <!-- Name input for anonymous users -->
        <input
          id="cert-name"
          type="text"
          placeholder={t("certificate.enter_name")}
          maxlength="60"
          data-track-title={track.title}
          data-track-id={track.id}
          class="hidden w-full px-4 py-2.5 rounded-lg bg-light-bg border border-stroke-color text-secondary placeholder:text-secondary/30 focus:outline-none focus:border-yellow transition-colors font-medium"
        />

        <!-- Share buttons (shown after cert is claimed) -->
        <div id="share-buttons" class="hidden flex-col gap-3 pt-4 border-t border-stroke-color/30">
          <p class="text-xs text-secondary/40">{t("certificate.share_title")}</p>
          <div class="flex flex-col gap-2">
            <a
              id="linkedin-btn"
              href="#"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center gap-2 py-2.5 text-sm font-semibold rounded-lg border border-stroke-color text-secondary/60 hover:border-[#0A66C2] hover:text-[#0A66C2] transition-all"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              {t("certificate.linkedin_add")}
            </a>
            <a
              id="x-btn"
              href="#"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center gap-2 py-2.5 text-sm font-semibold rounded-lg border border-stroke-color text-secondary/60 hover:border-white hover:text-white transition-all"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.736-8.849L1.254 2.25H8.08l4.253 5.622L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
              </svg>
              {t("certificate.twitter_post")}
            </a>
          </div>
        </div>

      </div>

      <!-- RIGHT: Toggle + Canvas + Download -->
      <div class="flex-1 min-w-0 flex flex-col items-center gap-4 w-full">

        <!-- Mode toggle -->
        <div class="flex w-full rounded-xl border border-stroke-color overflow-hidden text-xs font-semibold">
          <button id="toggle-cert" class="flex-1 py-2.5 transition-colors bg-yellow text-primary">
            {t("certificate.toggle_cert")}
          </button>
          <button id="toggle-badge" class="flex-1 py-2.5 transition-colors text-secondary/50 hover:text-secondary/80">
            {t("certificate.toggle_badge")}
          </button>
        </div>

        <canvas
          id="certificate-canvas"
          width="900"
          height="636"
          class="w-full drop-shadow-2xl rounded-sm"
          data-logo-url={logoSvgUrl}
          data-brand-line1={t("certificate.brand_name_line1")}
          data-brand-line2={t("certificate.brand_name_line2")}
          data-awarded-in={t("certificate.awarded_in")}
          data-cert-title={t("certificate.certificate_title")}
          data-cert-subtitle={t("certificate.certificate_subtitle")}
          data-cert-intro={t("certificate.certificate_intro")}
          data-default-name={t("certificate.default_name")}
          data-completion-text={t("certificate.completion_text")}
          data-completion-suffix={t("certificate.course_completion_suffix")}
          data-issue-date-label={t("certificate.issue_date_label")}
          data-cert-id-label={t("certificate.certificate_id_label")}
          data-website-url={t("certificate.website_url")}
          data-badge-certification={t("certificate.badge_certification")}
        ></canvas>

        <button
          id="download-btn"
          class="flex items-center gap-2 rounded-lg bg-yellow px-8 py-3 font-semibold text-black hover:opacity-80 transition cursor-pointer"
        >
          {t("certificate.download_pdf")}
        </button>

      </div>

    </div>
  </main>
</Layout>

<script>
  function hexPath(ctx: CanvasRenderingContext2D, cx: number, cy: number, r: number) {
    ctx.beginPath()
    for (let i = 0; i < 6; i++) {
      const angle = (Math.PI / 3) * i - Math.PI / 2
      i === 0
        ? ctx.moveTo(cx + r * Math.cos(angle), cy + r * Math.sin(angle))
        : ctx.lineTo(cx + r * Math.cos(angle), cy + r * Math.sin(angle))
    }
    ctx.closePath()
  }

  // Badge = hexagonal design
  async function drawBadge(canvas: HTMLCanvasElement, trackTitle: string, name: string, logoUrl = "", badgeCertification = "Certificación", defaultName = "Tu Nombre", websiteUrl = "rustlings.rustlang-es.org") {
    canvas.width = 600
    canvas.height = 600
    const ctx = canvas.getContext("2d")!
    const W = canvas.width, H = canvas.height
    const cx = W / 2, cy = H / 2
    const ORANGE = "#FF6E1F"
    const LIGHT_GRAY = "#94a3b8"
    const R = 272
    const off = { icon: -148, title: -18, cert: 18, dots: 40, name: 82, date: 112, url: 170 }

    ctx.clearRect(0, 0, W, H)

    for (let i = 3; i >= 1; i--) {
      hexPath(ctx, cx, cy, R + i * 6)
      ctx.fillStyle = `rgba(255, 110, 31, ${0.06 * i})`
      ctx.fill()
    }

    hexPath(ctx, cx, cy, R)
    ctx.save()
    ctx.clip()
    const grad = ctx.createLinearGradient(cx, cy - R, cx, cy + R)
    grad.addColorStop(0, "#1e1e2e")
    grad.addColorStop(1, "#0d0d18")
    ctx.fillStyle = grad
    ctx.fillRect(0, 0, W, H)
    ctx.restore()

    hexPath(ctx, cx, cy, R)
    ctx.strokeStyle = ORANGE
    ctx.lineWidth = 3
    ctx.stroke()

    hexPath(ctx, cx, cy, R - 10)
    ctx.strokeStyle = "rgba(255, 110, 31, 0.25)"
    ctx.lineWidth = 1
    ctx.stroke()

    ctx.textAlign = "center"

    const iconY = cy + off.icon
    const logoImg = new Image()
    await new Promise<void>((resolve) => {
      logoImg.onload = () => resolve()
      logoImg.onerror = () => resolve()
      logoImg.src = logoUrl
    })
    const logoW = 140
    const logoH = Math.round(logoW * (500.97 / 814.04))
    ctx.drawImage(logoImg, cx - logoW / 2, iconY - logoH / 2, logoW, logoH)

    ctx.fillStyle = ORANGE
    ctx.font = "600 13px 'Poppins', sans-serif"
    ctx.letterSpacing = "2px"
    ctx.fillText("RUSTLANG EN ESPAÑOL", cx, iconY + 72)
    ctx.letterSpacing = "0px"

    ctx.strokeStyle = "rgba(255,110,31,0.35)"
    ctx.lineWidth = 1
    ctx.beginPath()
    ctx.moveTo(cx - 90, iconY + 86)
    ctx.lineTo(cx + 90, iconY + 86)
    ctx.stroke()

    ctx.fillStyle = "#ffffff"
    ctx.font = "700 40px 'Poppins', sans-serif"
    const maxW = R * 1.4
    if (ctx.measureText(trackTitle).width > maxW) {
      const scaled = Math.floor(40 * (maxW / ctx.measureText(trackTitle).width))
      ctx.font = `700 ${scaled}px 'Poppins', sans-serif`
    }
    ctx.fillText(trackTitle, cx, cy + off.title)

    ctx.fillStyle = ORANGE
    ctx.font = "600 17px 'Poppins', sans-serif"
    ctx.fillText(badgeCertification, cx, cy + off.cert)

    ctx.fillStyle = "rgba(255,110,31,0.4)"
    for (let i = -1; i <= 1; i++) {
      ctx.beginPath()
      ctx.arc(cx + i * 14, cy + off.dots, 2.5, 0, Math.PI * 2)
      ctx.fill()
    }

    const displayName = name.trim() || defaultName
    ctx.fillStyle = "#e2e8f0"
    ctx.font = "700 26px 'Poppins', sans-serif"
    const maxNameW = R * 1.5
    if (ctx.measureText(displayName).width > maxNameW) {
      const scaled = Math.floor(26 * (maxNameW / ctx.measureText(displayName).width))
      ctx.font = `700 ${scaled}px 'Poppins', sans-serif`
    }
    ctx.fillText(displayName, cx, cy + off.name)

    const date = new Date().toLocaleDateString("es-MX", { year: "numeric", month: "short", day: "numeric" })
    ctx.fillStyle = LIGHT_GRAY
    ctx.font = "400 13px 'Poppins', sans-serif"
    ctx.fillText(date, cx, cy + off.date)

    ctx.fillStyle = "rgba(148,163,184,0.5)"
    ctx.font = "400 11px 'Poppins', sans-serif"
    ctx.fillText(websiteUrl, cx, cy + off.url)
  }

  // Certificate = formal horizontal landscape design
  async function drawCertificate(
    canvas: HTMLCanvasElement,
    trackTitle: string,
    name: string,
    logoUrl = "",
    translations: {
      brandLine1: string,
      brandLine2: string,
      awardedIn: string,
      certTitle: string,
      certSubtitle: string,
      certIntro: string,
      defaultName: string,
      completionText: string,
      completionSuffix: string,
      issueDateLabel: string,
      certIdLabel: string,
      websiteUrl: string
    },
    issuedAt?: string,
    certId?: string,
  ) {
    canvas.width = 900
    canvas.height = 636
    const ctx = canvas.getContext("2d")!
    const W = 900, H = 636
    const ORANGE = "#FF6E1F"
    const DARK_NAVY = "#0d1628"
    const SIDEBAR_W = 185

    ctx.clearRect(0, 0, W, H)

    // White/light background
    ctx.fillStyle = "#f8fafc"
    ctx.fillRect(0, 0, W, H)

    // Left sidebar (dark navy)
    ctx.fillStyle = DARK_NAVY
    ctx.fillRect(0, 0, SIDEBAR_W, H)

    // Orange accent stripe on right edge of sidebar
    ctx.fillStyle = ORANGE
    ctx.fillRect(SIDEBAR_W - 5, 0, 5, H)

    // Logo in sidebar
    const logoImg = new Image()
    await new Promise<void>((resolve) => {
      logoImg.onload = () => resolve()
      logoImg.onerror = () => resolve()
      logoImg.src = logoUrl
    })
    const logoW = 110
    const logoH = Math.round(logoW * (500.97 / 814.04))
    ctx.drawImage(logoImg, (SIDEBAR_W - logoW) / 2, H / 2 - logoH / 2 - 16, logoW, logoH)

    ctx.textAlign = "center"
    ctx.fillStyle = "rgba(255,255,255,0.4)"
    ctx.font = "500 9px 'Poppins', sans-serif"
    ctx.letterSpacing = "1.5px"
    ctx.fillText(translations.brandLine1, SIDEBAR_W / 2, H / 2 + logoH / 2 + 10)
    ctx.fillText(translations.brandLine2, SIDEBAR_W / 2, H / 2 + logoH / 2 + 24)
    ctx.letterSpacing = "0px"

    const cX = SIDEBAR_W + 48
    const cRight = W - 48

    // Gold seal (top right)
    const sX = cRight - 52
    const sY = 68
    const sR = 50
    const goldGrad = ctx.createRadialGradient(sX - 12, sY - 12, 5, sX, sY, sR)
    goldGrad.addColorStop(0, "#fef08a")
    goldGrad.addColorStop(0.4, "#eab308")
    goldGrad.addColorStop(1, "#92400e")
    ctx.beginPath()
    ctx.arc(sX, sY, sR, 0, Math.PI * 2)
    ctx.fillStyle = goldGrad
    ctx.fill()
    ctx.beginPath()
    ctx.arc(sX, sY, sR - 5, 0, Math.PI * 2)
    ctx.strokeStyle = "rgba(255,255,255,0.4)"
    ctx.lineWidth = 1.5
    ctx.stroke()
    ctx.textAlign = "center"
    ctx.fillStyle = "#ffffff"
    ctx.font = "bold 10px sans-serif"
    ctx.fillText("★  ★  ★", sX, sY - 18)
    ctx.font = "bold 20px 'Poppins', sans-serif"
    ctx.fillText(String(new Date().getFullYear()), sX, sY + 6)
    ctx.fillStyle = "rgba(255,255,255,0.85)"
    ctx.font = "600 7px 'Poppins', sans-serif"
    ctx.letterSpacing = "0.5px"
    ctx.fillText(translations.awardedIn, sX, sY + 19)
    ctx.letterSpacing = "0px"
    // Ribbons
    ctx.fillStyle = "#1e3a8a"
    ctx.beginPath()
    ctx.moveTo(sX - 13, sY + sR); ctx.lineTo(sX - 21, sY + sR + 26); ctx.lineTo(sX - 5, sY + sR + 14)
    ctx.closePath(); ctx.fill()
    ctx.beginPath()
    ctx.moveTo(sX + 13, sY + sR); ctx.lineTo(sX + 21, sY + sR + 26); ctx.lineTo(sX + 5, sY + sR + 14)
    ctx.closePath(); ctx.fill()

    // Certificate title and subtitle
    ctx.textAlign = "left"
    ctx.fillStyle = DARK_NAVY
    ctx.font = "900 58px 'Poppins', sans-serif"
    ctx.fillText(translations.certTitle, cX, 84)

    ctx.fillStyle = ORANGE
    ctx.font = "700 23px 'Poppins', sans-serif"
    ctx.fillText(translations.certSubtitle, cX, 116)

    // Divider
    ctx.strokeStyle = "rgba(0,0,0,0.08)"
    ctx.lineWidth = 1
    ctx.beginPath()
    ctx.moveTo(cX, 134)
    ctx.lineTo(sX - sR - 16, 134)
    ctx.stroke()

    // Certificate intro text
    ctx.fillStyle = "#64748b"
    ctx.font = "400 13px 'Poppins', sans-serif"
    ctx.fillText(translations.certIntro, cX, 172)

    // Recipient name (large italic)
    const displayName = name.trim() || translations.defaultName
    ctx.fillStyle = DARK_NAVY
    ctx.font = "italic 700 46px 'Georgia', serif"
    const maxNameW = cRight - cX - 20
    if (ctx.measureText(displayName).width > maxNameW) {
      const scaled = Math.floor(46 * (maxNameW / ctx.measureText(displayName).width))
      ctx.font = `italic 700 ${scaled}px 'Georgia', serif`
    }
    ctx.fillText(displayName, cX, 236)

    // Underline name
    ctx.strokeStyle = "rgba(0,0,0,0.1)"
    ctx.lineWidth = 1
    ctx.beginPath()
    ctx.moveTo(cX, 252)
    ctx.lineTo(cX + Math.min(ctx.measureText(displayName).width + 20, 340), 252)
    ctx.stroke()

    // Description
    ctx.fillStyle = "#475569"
    ctx.font = "400 13px 'Poppins', sans-serif"
    ctx.fillText(translations.completionText, cX, 290)
    ctx.fillStyle = DARK_NAVY
    ctx.font = "600 13px 'Poppins', sans-serif"
    const courseLabel = `"${trackTitle}" ${translations.completionSuffix}`
    if (ctx.measureText(courseLabel).width > maxNameW) {
      ctx.fillText(`"${trackTitle}"`, cX, 308)
      ctx.fillText(translations.completionSuffix, cX, 324)
    } else {
      ctx.fillText(courseLabel, cX, 308)
    }

    // Bottom divider
    ctx.strokeStyle = "rgba(0,0,0,0.08)"
    ctx.lineWidth = 1
    ctx.beginPath()
    ctx.moveTo(cX, 488)
    ctx.lineTo(cRight, 488)
    ctx.stroke()

    // Date
    const date = issuedAt
      ? new Date(issuedAt).toLocaleDateString("es-MX", { year: "numeric", month: "2-digit", day: "2-digit" })
      : new Date().toLocaleDateString("es-MX", { year: "numeric", month: "2-digit", day: "2-digit" })
    ctx.textAlign = "left"
    ctx.fillStyle = "#94a3b8"
    ctx.font = "500 10px 'Poppins', sans-serif"
    ctx.letterSpacing = "0.5px"
    ctx.fillText(translations.issueDateLabel, cX, 514)
    ctx.letterSpacing = "0px"
    ctx.fillStyle = DARK_NAVY
    ctx.font = "600 12px 'Poppins', sans-serif"
    ctx.fillText(date, cX, 530)

    // Cert ID
    if (certId) {
      ctx.textAlign = "right"
      ctx.fillStyle = "#94a3b8"
      ctx.font = "500 10px 'Poppins', sans-serif"
      ctx.letterSpacing = "0.5px"
      ctx.fillText(translations.certIdLabel, cRight, 514)
      ctx.letterSpacing = "0px"
      ctx.fillStyle = DARK_NAVY
      ctx.font = "600 11px 'Poppins', sans-serif"
      ctx.fillText(certId.slice(0, 22), cRight, 530)
    }

    // URL
    ctx.textAlign = "center"
    ctx.fillStyle = "#94a3b8"
    ctx.font = "400 11px 'Poppins', sans-serif"
    ctx.fillText(translations.websiteUrl, (cX + cRight) / 2, 568)
  }

  document.addEventListener("astro:page-load", async () => {
    const canvas = document.getElementById("certificate-canvas") as HTMLCanvasElement
    const nameInput = document.getElementById("cert-name") as HTMLInputElement
    const nameDisplay = document.getElementById("cert-name-display") as HTMLDivElement
    const nameText = document.getElementById("cert-name-text") as HTMLElement
    const subtitle = document.getElementById("cert-subtitle") as HTMLElement
    const trackTitle = nameInput.dataset.trackTitle!
    const trackId = nameInput.dataset.trackId!
    const logoUrl = canvas.dataset.logoUrl!

    let certName = ""
    let currentCertId = ""
    let currentIssuedAt = ""
    let mode: "cert" | "badge" = "cert"

    // Toggle buttons
    const toggleCertBtn = document.getElementById("toggle-cert") as HTMLButtonElement
    const toggleBadgeBtn = document.getElementById("toggle-badge") as HTMLButtonElement

    const setMode = (m: "cert" | "badge") => {
      mode = m
      const isC = m === "cert"
      toggleCertBtn.className = `flex-1 py-2.5 transition-colors ${isC ? "bg-yellow text-primary" : "text-secondary/50 hover:text-secondary/80"}`
      toggleBadgeBtn.className = `flex-1 py-2.5 transition-colors ${!isC ? "bg-yellow text-primary" : "text-secondary/50 hover:text-secondary/80"}`
      canvas.className = isC
        ? "w-full drop-shadow-2xl rounded-sm"
        : "drop-shadow-2xl rounded-sm w-[500px] max-w-full mx-auto"
      redraw()
    }
    toggleCertBtn.addEventListener("click", () => setMode("cert"))
    toggleBadgeBtn.addEventListener("click", () => setMode("badge"))

    const showShareButtons = (certId: string, issuedAt: string) => {
      currentCertId = certId
      currentIssuedAt = issuedAt
      redraw()

      const shareDiv = document.getElementById("share-buttons")!
      const linkedinBtn = document.getElementById("linkedin-btn") as HTMLAnchorElement
      const xBtn = document.getElementById("x-btn") as HTMLAnchorElement
      const certUrl = `${window.location.origin}/verificar/${certId}`
      const issued = new Date(issuedAt)

      const linkedinParams = new URLSearchParams({
        startTask: "CERTIFICATION_NAME",
        name: trackTitle,
        organizationId: "100302734",
        issueYear: String(issued.getFullYear()),
        issueMonth: String(issued.getMonth() + 1),
        certUrl,
        certId,
      })
      linkedinBtn.href = `https://www.linkedin.com/profile/add?${linkedinParams}`

      const xText = `¡Completé "${trackTitle}" en @rust_lang_es 🦀\nVer mi certificado: ${certUrl}`
      xBtn.href = `https://x.com/intent/post?text=${encodeURIComponent(xText)}`

      shareDiv.classList.remove("hidden")
      shareDiv.classList.add("flex")
    }

    // Try to load name from user profile
    try {
      const res = await fetch("/api/auth/me")
      if (res.ok) {
        const { fullName } = await res.json() as { fullName: string | null }
        if (fullName) {
          certName = fullName
          nameText.textContent = fullName
          nameDisplay.classList.remove("hidden")
          nameDisplay.classList.add("flex")
          subtitle.textContent = "Tu nombre se toma de tu perfil"

          fetch("/api/certificates/claim", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ courseId: trackId, nameUsed: fullName }),
          })
            .then((r) => r.json())
            // @ts-ignore
            .then(({ certId, issuedAt }: { certId?: string; issuedAt?: string }) => {
              if (certId && issuedAt) showShareButtons(certId, issuedAt)
            })
            .catch(() => {})
        } else {
          nameDisplay.classList.remove("hidden")
          nameDisplay.classList.add("flex")
          nameText.textContent = "Sin nombre configurado"
          subtitle.textContent = "Configura tu nombre en tu perfil"
        }
      } else {
        nameInput.classList.remove("hidden")
        subtitle.textContent = "Ingresa tu nombre para personalizar el certificado"
      }
    } catch {
      nameInput.classList.remove("hidden")
      subtitle.textContent = "Ingresa tu nombre para personalizar el certificado"
    }

    const getName = () => certName || nameInput.value

    // Get translations from canvas data attributes
    const { 
      brandLine1, brandLine2, awardedIn, certTitle, certSubtitle,
      certIntro, defaultName, completionText, completionSuffix,
      issueDateLabel, certIdLabel, websiteUrl, badgeCertification
    } = canvas.dataset as Record<string, string>

    const translations = {
      brandLine1, brandLine2, awardedIn, certTitle, certSubtitle,
      certIntro, defaultName, completionText, completionSuffix,
      issueDateLabel, certIdLabel, websiteUrl
    }

    const redraw = () => {
      const name = getName()
      if (mode === "badge") {
        document.fonts.ready.then(() => drawBadge(canvas, trackTitle, name, logoUrl, badgeCertification, defaultName, websiteUrl))
      } else {
        document.fonts.ready.then(() =>
          drawCertificate(canvas, trackTitle, name, logoUrl, translations, currentIssuedAt || undefined, currentCertId || undefined),
        )
      }
    }

    redraw()
    nameInput.addEventListener("input", redraw)

    document.getElementById("download-btn")?.addEventListener("click", () => {
      const link = document.createElement("a")
      const slug = trackTitle.toLowerCase().replace(/\s+/g, "-")
      link.download = mode === "badge" ? `badge-${slug}.png` : `certificado-${slug}.png`
      link.href = canvas.toDataURL("image/png")
      link.click()

      const name = getName().trim()
      if (name && !certName) {
        fetch("/api/certificates/claim", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ courseId: trackId, nameUsed: name }),
        }).catch(() => {})
      }
    })
  })
</script>
