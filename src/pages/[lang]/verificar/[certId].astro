---
import { tracks } from "~/const/tracks"
import { getLangFromUrl, useTranslations } from "~/i18n/utils"
import Layout from "~/layouts/Layout.astro"
import IconLeft from "~icons/tabler/arrow-big-left-lines-filled"
import IconCertificate from "~icons/tabler/certificate"

const logoSvgUrl = "/Rust_Lang_ES_Logo_Blanco_color.svg"
const { certId } = Astro.params
const { DB } = Astro.locals.runtime.env
const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

interface CertRow {
	id: string
	user_id: string
	course_id: string
	name_used: string
	issued_at: string
}

const cert = await DB.prepare("SELECT id, user_id, course_id, name_used, issued_at FROM user_certificates WHERE id = ?")
	.bind(certId)
	.first<CertRow>()

if (!cert) {
	return new Response(null, { status: 404 })
}

const track = tracks.find((t) => t.id === cert.course_id)
const issuedDate = new Date(cert.issued_at).toLocaleDateString(lang === "es" ? "es-MX" : "en-US", {
	year: "numeric",
	month: "long",
	day: "numeric",
})
---

<Layout title={t("verification.title", { name: cert.name_used })}>
  <header class="p-2 w-full shrink-0">
    <nav class="relative z-50 flex items-center justify-between px-3 py-1 border border-stroke-color backdrop-blur-md bg-bg-nav rounded-md shadow-lg">
      <a
        href={`/${lang}/`}
        class="flex items-center gap-2 px-3 py-1.5 text-sm font-medium text-secondary/60 border border-transparent rounded-lg hover:border-yellow hover:text-yellow transition-all duration-300"
      >
        <IconLeft font-size={20} />
        {t("verification.back_home")}
      </a>
    </nav>
  </header>

  <main class="flex-1 flex flex-col items-center px-4 py-10 gap-6">
    <!-- Verification badge -->
    <div class="flex flex-col items-center gap-2 text-center">
      <div class="flex items-center gap-2 px-4 py-1.5 bg-green-500/10 border border-green-500/30 rounded-full">
        <IconCertificate font-size={14} class="text-green-400" />
        <span class="text-xs font-semibold text-green-400">{t("verification.verified_badge")}</span>
      </div>
      <h1 class="text-2xl font-bold text-secondary mt-2">{cert.name_used}</h1>
      <p class="text-secondary/50 text-sm">
        {t("verification.completed")} <span class="text-secondary font-semibold">{track ? t(track.title) : cert.course_id}</span>
      </p>
      <p class="text-secondary/30 text-xs">{t("verification.issued_date")}: {issuedDate}</p>
    </div>

    <!-- Certificate canvas -->
    <div class="w-full max-w-3xl flex flex-col items-center gap-4">
      <canvas
        id="certificate-canvas"
        width="900"
        height="636"
        class="w-full drop-shadow-2xl rounded-sm"
        data-logo-url={logoSvgUrl}
        data-name={cert.name_used}
        data-track-title={track ? t(track.title) : cert.course_id}
        data-issued-at={cert.issued_at}
        data-cert-id={cert.id}
        data-brand-line1={t("certificate.brand_name_line1")}
        data-brand-line2={t("certificate.brand_name_line2")}
        data-awarded-in={t("certificate.awarded_in")}
        data-cert-title={t("certificate.certificate_title")}
        data-cert-subtitle={t("certificate.certificate_subtitle")}
        data-cert-intro={t("certificate.certificate_intro")}
        data-default-name={t("certificate.default_name")}
        data-completion-text={t("certificate.completion_text")}
        data-completion-suffix={t("certificate.course_completion_suffix")}
        data-issue-date-label={t("certificate.issue_date_label")}
        data-cert-id-label={t("certificate.certificate_id_label")}
        data-website-url={t("certificate.website_url")}
      ></canvas>
    </div>
  </main>
</Layout>

<script>
  async function drawCertificate(
    canvas: HTMLCanvasElement,
    trackTitle: string,
    name: string,
    logoUrl: string,
    translations: {
      brandLine1: string,
      brandLine2: string,
      awardedIn: string,
      certTitle: string,
      certSubtitle: string,
      certIntro: string,
      defaultName: string,
      completionText: string,
      completionSuffix: string,
      issueDateLabel: string,
      certIdLabel: string,
      websiteUrl: string
    },
    issuedAt?: string,
    certId?: string,
  ) {
    canvas.width = 900
    canvas.height = 636
    const ctx = canvas.getContext("2d")!
    const W = 900, H = 636
    const ORANGE = "#FF6E1F"
    const DARK_NAVY = "#0d1628"
    const SIDEBAR_W = 185

    ctx.clearRect(0, 0, W, H)

    // White/light background
    ctx.fillStyle = "#f8fafc"
    ctx.fillRect(0, 0, W, H)

    // Left sidebar (dark navy)
    ctx.fillStyle = DARK_NAVY
    ctx.fillRect(0, 0, SIDEBAR_W, H)

    // Orange accent stripe on right edge of sidebar
    ctx.fillStyle = ORANGE
    ctx.fillRect(SIDEBAR_W - 5, 0, 5, H)

    // Logo in sidebar
    const logoImg = new Image()
    await new Promise<void>((resolve) => {
      logoImg.onload = () => resolve()
      logoImg.onerror = () => resolve()
      logoImg.src = logoUrl
    })
    const logoW = 110
    const logoH = Math.round(logoW * (500.97 / 814.04))
    ctx.drawImage(logoImg, (SIDEBAR_W - logoW) / 2, H / 2 - logoH / 2 - 16, logoW, logoH)

    // Brand text under logo
    ctx.textAlign = "center"
    ctx.fillStyle = "rgba(255,255,255,0.4)"
    ctx.font = "500 9px 'Poppins', sans-serif"
    ctx.letterSpacing = "1.5px"
    ctx.fillText(translations.brandLine1, SIDEBAR_W / 2, H / 2 + logoH / 2 + 10)
    ctx.fillText(translations.brandLine2, SIDEBAR_W / 2, H / 2 + logoH / 2 + 24)
    ctx.letterSpacing = "0px"

    // Main content bounds
    const cX = SIDEBAR_W + 48
    const cRight = W - 48

    // Gold seal (top right)
    const sX = cRight - 52
    const sY = 68
    const sR = 50
    const goldGrad = ctx.createRadialGradient(sX - 12, sY - 12, 5, sX, sY, sR)
    goldGrad.addColorStop(0, "#fef08a")
    goldGrad.addColorStop(0.4, "#eab308")
    goldGrad.addColorStop(1, "#92400e")
    ctx.beginPath()
    ctx.arc(sX, sY, sR, 0, Math.PI * 2)
    ctx.fillStyle = goldGrad
    ctx.fill()
    ctx.beginPath()
    ctx.arc(sX, sY, sR - 5, 0, Math.PI * 2)
    ctx.strokeStyle = "rgba(255,255,255,0.4)"
    ctx.lineWidth = 1.5
    ctx.stroke()
    ctx.textAlign = "center"
    ctx.fillStyle = "#ffffff"
    ctx.font = "bold 10px sans-serif"
    ctx.fillText("★  ★  ★", sX, sY - 18)
    ctx.font = "bold 20px 'Poppins', sans-serif"
    ctx.fillText(String(new Date().getFullYear()), sX, sY + 6)
    ctx.fillStyle = "rgba(255,255,255,0.85)"
    ctx.font = "600 7px 'Poppins', sans-serif"
    ctx.letterSpacing = "0.5px"
    ctx.fillText(translations.awardedIn, sX, sY + 19)
    ctx.letterSpacing = "0px"
    // Ribbons
    ctx.fillStyle = "#1e3a8a"
    ctx.beginPath()
    ctx.moveTo(sX - 13, sY + sR); ctx.lineTo(sX - 21, sY + sR + 26); ctx.lineTo(sX - 5, sY + sR + 14)
    ctx.closePath(); ctx.fill()
    ctx.beginPath()
    ctx.moveTo(sX + 13, sY + sR); ctx.lineTo(sX + 21, sY + sR + 26); ctx.lineTo(sX + 5, sY + sR + 14)
    ctx.closePath(); ctx.fill()

    // Certificate title
    ctx.textAlign = "left"
    ctx.fillStyle = DARK_NAVY
    ctx.font = "900 58px 'Poppins', sans-serif"
    ctx.fillText(translations.certTitle, cX, 84)

    // Certificate subtitle
    ctx.fillStyle = ORANGE
    ctx.font = "700 23px 'Poppins', sans-serif"
    ctx.fillText(translations.certSubtitle, cX, 116)

    // Divider
    ctx.strokeStyle = "rgba(0,0,0,0.08)"
    ctx.lineWidth = 1
    ctx.beginPath()
    ctx.moveTo(cX, 134)
    ctx.lineTo(sX - sR - 16, 134)
    ctx.stroke()

    // Certificate intro text
    ctx.fillStyle = "#64748b"
    ctx.font = "400 13px 'Poppins', sans-serif"
    ctx.fillText(translations.certIntro, cX, 172)

    // Recipient name (large italic)
    const displayName = name.trim() || translations.defaultName
    ctx.fillStyle = DARK_NAVY
    ctx.font = "italic 700 46px 'Georgia', serif"
    const maxNameW = cRight - cX - 20
    if (ctx.measureText(displayName).width > maxNameW) {
      const scaled = Math.floor(46 * (maxNameW / ctx.measureText(displayName).width))
      ctx.font = `italic 700 ${scaled}px 'Georgia', serif`
    }
    ctx.fillText(displayName, cX, 236)

    // Underline name
    ctx.strokeStyle = "rgba(0,0,0,0.1)"
    ctx.lineWidth = 1
    ctx.beginPath()
    ctx.moveTo(cX, 252)
    ctx.lineTo(cX + Math.min(ctx.measureText(displayName).width + 20, 340), 252)
    ctx.stroke()

    // Description
    ctx.fillStyle = "#475569"
    ctx.font = "400 13px 'Poppins', sans-serif"
    ctx.fillText(translations.completionText, cX, 290)
    ctx.fillStyle = DARK_NAVY
    ctx.font = "600 13px 'Poppins', sans-serif"
    const courseLabel = `"${trackTitle}" ${translations.completionSuffix}`
    if (ctx.measureText(courseLabel).width > maxNameW) {
      ctx.fillText(`"${trackTitle}"`, cX, 308)
      ctx.fillText(translations.completionSuffix, cX, 324)
    } else {
      ctx.fillText(courseLabel, cX, 308)
    }

    // Bottom divider
    ctx.strokeStyle = "rgba(0,0,0,0.08)"
    ctx.lineWidth = 1
    ctx.beginPath()
    ctx.moveTo(cX, 488)
    ctx.lineTo(cRight, 488)
    ctx.stroke()

    // Date
    const date = issuedAt
      ? new Date(issuedAt).toLocaleDateString("es-MX", { year: "numeric", month: "2-digit", day: "2-digit" })
      : new Date().toLocaleDateString("es-MX", { year: "numeric", month: "2-digit", day: "2-digit" })
    ctx.textAlign = "left"
    ctx.fillStyle = "#94a3b8"
    ctx.font = "500 10px 'Poppins', sans-serif"
    ctx.letterSpacing = "0.5px"
    ctx.fillText(translations.issueDateLabel, cX, 514)
    ctx.letterSpacing = "0px"
    ctx.fillStyle = DARK_NAVY
    ctx.font = "600 12px 'Poppins', sans-serif"
    ctx.fillText(date, cX, 530)

    // Cert ID
    if (certId) {
      ctx.textAlign = "right"
      ctx.fillStyle = "#94a3b8"
      ctx.font = "500 10px 'Poppins', sans-serif"
      ctx.letterSpacing = "0.5px"
      ctx.fillText(translations.certIdLabel, cRight, 514)
      ctx.letterSpacing = "0px"
      ctx.fillStyle = DARK_NAVY
      ctx.font = "600 11px 'Poppins', sans-serif"
      ctx.fillText(certId.slice(0, 22), cRight, 530)
    }

    // URL
    ctx.textAlign = "center"
    ctx.fillStyle = "#94a3b8"
    ctx.font = "400 11px 'Poppins', sans-serif"
    ctx.fillText(translations.websiteUrl, (cX + cRight) / 2, 568)
  }

  document.addEventListener("astro:page-load", () => {
    const canvas = document.getElementById("certificate-canvas") as HTMLCanvasElement
    const { 
      logoUrl, name, trackTitle, issuedAt, certId,
      brandLine1, brandLine2, awardedIn, certTitle, certSubtitle,
      certIntro, defaultName, completionText, completionSuffix,
      issueDateLabel, certIdLabel, websiteUrl
    } = canvas.dataset as Record<string, string>

    const translations = {
      brandLine1, brandLine2, awardedIn, certTitle, certSubtitle,
      certIntro, defaultName, completionText, completionSuffix,
      issueDateLabel, certIdLabel, websiteUrl
    }

    document.fonts.ready.then(() => drawCertificate(canvas, trackTitle, name, logoUrl, translations, issuedAt, certId))
  })
</script>
