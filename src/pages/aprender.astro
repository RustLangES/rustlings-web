---
import { Image } from "astro:assets"
import logoImage from "~/assets/images/webp/logo.webp"
import { tracks } from "~/const/tracks"
import { getLangFromUrl, useTranslations } from "~/i18n/utils"
import Layout from "~/layouts/Layout.astro"
import IconLeft from "~icons/tabler/arrow-big-left-lines-filled"
import IconRight from "~icons/tabler/arrow-big-right-lines-filled"
import IconLogout from "~icons/tabler/logout"
import IconUser from "~icons/tabler/user"

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
const user = Astro.locals.user
---

<Layout
  title="¿Qué quieres aprender? — Rustlings Web"
  description="Elige el tema que deseas aprender en Rustlings Web."
>
  <header class="p-2 w-full">
    <nav class="relative z-50 flex items-center justify-between px-3 py-1 border border-stroke-color backdrop-blur-md bg-bg-nav rounded-md shadow-lg">
      <a
        href="/"
        class="flex items-center gap-2 px-3 py-1.5 text-sm font-medium text-secondary/60 border border-transparent rounded-lg hover:border-yellow hover:text-yellow transition-all duration-300"
      >
        <IconLeft font-size={20} />
        Inicio
      </a>

      {user ? (
        <div class="flex items-center gap-2">
          <a
            href="/perfil"
            class="flex items-center gap-2 px-3 py-1.5 text-sm text-secondary/70 border border-transparent rounded-lg hover:border-yellow/40 hover:text-secondary transition-all"
          >
            <IconUser font-size={16} />
            <span class="hidden sm:inline">{user.username ?? user.email}</span>
          </a>
          <a
            href="/api/auth/logout"
            data-astro-reload
            class="flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-secondary/50 border border-transparent rounded-lg hover:border-red-500/40 hover:text-red-400 transition-all duration-300"
            title="Cerrar sesión"
          >
            <IconLogout font-size={16} />
            <span class="hidden sm:inline">Salir</span>
          </a>
        </div>
      ) : (
        <a
          href="/login"
          class="flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-secondary/60 border border-transparent rounded-lg hover:border-yellow hover:text-yellow transition-all duration-300"
        >
          <IconUser font-size={16} />
          Iniciar sesión
        </a>
      )}
    </nav>
  </header>

  <main class="flex-1 flex flex-col px-6 py-12">

    <div class="flex flex-col items-center text-center mb-12">
      <h1 class="text-2xl md:text-3xl font-bold text-secondary">¿Qué quieres aprender?</h1>
      <p class="text-secondary/50 text-sm">Elige un camino para comenzar tu aventura</p>
    </div>

    <div class="flex flex-col items-center">
      <div class="w-full max-w-2xl flex flex-col gap-4">
        {tracks.map(track => (
          track.disabled ? (
            <div class="relative flex gap-3 sm:gap-6 items-start bg-light-bg/40 border border-stroke-color/40 rounded-2xl p-4 sm:p-6 cursor-not-allowed opacity-50 select-none">
              <div class="absolute top-3 right-3 flex items-center gap-1.5">
                <span class="text-xs bg-stroke-color/30 text-secondary/40 border border-stroke-color/30 px-2 py-0.5 rounded-full whitespace-nowrap">
                  {t(track.badge)}
                </span>
                <span class="text-xs bg-editor-bg text-secondary/50 border border-stroke-color/40 px-2 py-0.5 rounded-full whitespace-nowrap">
                  Próximamente
                </span>
              </div>

              <div class="shrink-0 w-12 h-12 sm:w-20 sm:h-20 flex items-center justify-center rounded-xl sm:rounded-2xl bg-editor-bg border border-stroke-color/40 mt-0.5">
                <Image src={logoImage} alt="Rustlings" class="w-8 h-8 sm:w-12 sm:h-12 grayscale" />
              </div>

              <div class="flex flex-col gap-1.5 flex-1 min-w-0">
                <span class="text-secondary/50 font-bold text-base sm:text-xl leading-tight">{track.title}</span>
                <p class="text-secondary/40 text-xs sm:text-sm leading-relaxed">{track.description}</p>
                <span class="text-secondary/30 text-xs">{track.lessons} lecciones</span>
              </div>
            </div>
          ) : (
            <div
              data-track-id={track.id}
              data-track-total={track.lessons}
              data-track-title={track.title}
              data-track-href={`/${lang}${track.href}`}
              data-track-slugs={JSON.stringify(track.slugs)}
              class="group relative flex gap-3 sm:gap-6 items-start bg-light-bg border border-stroke-color rounded-2xl p-4 sm:p-6 hover:border-yellow transition-all duration-200 cursor-pointer"
            >
              <span class="absolute top-3 right-3 text-xs bg-yellow/10 text-yellow border border-yellow/20 px-2 py-0.5 rounded-full whitespace-nowrap">
                {t(track.badge)}
              </span>

              <div class="shrink-0 w-12 h-12 sm:w-20 sm:h-20 flex items-center justify-center rounded-xl sm:rounded-2xl bg-editor-bg border border-stroke-color mt-0.5">
                <Image src={logoImage} alt="Rustlings" class="w-8 h-8 sm:w-12 sm:h-12" />
              </div>

              <div class="flex flex-col gap-1.5 sm:gap-2 flex-1 min-w-0">
                <span class="text-secondary font-bold text-base sm:text-xl group-hover:text-yellow transition-colors leading-tight pr-20">
                  {track.title}
                </span>
                <p class="text-secondary/60 text-xs sm:text-sm leading-relaxed">{track.description}</p>

                <!-- Progress bar (hidden until JS populates it) -->
                <div data-progress-container class="hidden flex-col gap-1 mt-0.5">
                  <div class="flex justify-between items-center">
                    <span data-progress-label class="text-xs text-secondary/50"></span>
                    <span data-progress-pct class="text-xs text-yellow font-medium"></span>
                  </div>
                  <div class="w-full h-1.5 bg-stroke-color/30 rounded-full overflow-hidden">
                    <div data-progress-bar class="h-full bg-yellow rounded-full transition-all duration-500" style="width:0%"></div>
                  </div>
                </div>

                <span data-lessons-label class="text-secondary/40 text-xs">{track.lessons} lecciones</span>
              </div>

              <span class="text-secondary/30 group-hover:text-yellow group-hover:translate-x-1 transition-all shrink-0 self-end mb-0.5">
                <IconRight font-size={20} />
              </span>
            </div>
          )
        ))}
      </div>
    </div>

  </main>

</Layout>

<script>
  import { db } from "~/lib/stores/editor-store"
  import { getTrackProgress } from "~/lib/progress"

  document.addEventListener("astro:page-load", async () => {
    // Sync server progress into local IndexedDB (no-op if not logged in)
    await db.syncFromServer()

    const cards = document.querySelectorAll<HTMLElement>("[data-track-id]")

    for (const card of cards) {
      const trackId = card.dataset.trackId!
      const total = Number(card.dataset.trackTotal)
      const slugs: string[] = JSON.parse(card.dataset.trackSlugs ?? "[]")

      // Use server-synced IndexedDB completions as source of truth
      const completions = slugs.length > 0
        ? await Promise.all(slugs.map((s) => db.isCompleted(s)))
        : []
      const completedCount = completions.filter(Boolean).length

      // Fall back to visited count if no completions yet
      const visited = getTrackProgress(trackId)
      const displayCount = completedCount > 0 ? completedCount : visited.length

      if (displayCount > 0) {
        const pct = Math.round((displayCount / total) * 100)
        const container = card.querySelector<HTMLElement>("[data-progress-container]")
        const label = card.querySelector<HTMLElement>("[data-progress-label]")
        const pctEl = card.querySelector<HTMLElement>("[data-progress-pct]")
        const bar = card.querySelector<HTMLElement>("[data-progress-bar]")
        const lessonsLabel = card.querySelector<HTMLElement>("[data-lessons-label]")

        if (container && label && pctEl && bar) {
          label.textContent = `${displayCount} de ${total} lecciones`
          pctEl.textContent = `${pct}%`
          bar.style.width = `${pct}%`
          container.classList.remove("hidden")
          container.classList.add("flex")
          if (lessonsLabel) lessonsLabel.classList.add("hidden")
        }
      }

      // Card click → navigate
      card.addEventListener("click", () => {
        window.location.href = card.dataset.trackHref!
      })
    }
  })
</script>
