---
import logoSvgUrl from "~/assets/Rust_Lang_ES_Logo_Blanco_color.svg?url"
import { tracks } from "~/const/tracks"
import Layout from "~/layouts/Layout.astro"
import IconLeft from "~icons/tabler/arrow-big-left-lines-filled"

export function getStaticPaths() {
	return tracks
		.filter((t) => !t.disabled && t.slugs.length > 0)
		.map((t) => ({ params: { trackId: t.id }, props: { track: t } }))
}

const { track } = Astro.props
---

<Layout title={`Certificado — ${track.title}`}>
  <header class="p-2 w-full shrink-0">
    <nav class="relative z-50 flex items-center justify-between px-3 py-1 border border-stroke-color backdrop-blur-md bg-bg-nav rounded-md shadow-l
    ">
      <a
        href="/aprender"
        class="flex items-center gap-2 px-3 py-1.5 text-sm font-medium text-secondary/60 border border-transparent rounded-lg hover:border-yellow hover:text-yellow transition-all duration-300"
      >
        <IconLeft font-size={20} />
        Volver
      </a>
    </nav>
  </header>

  <main class="flex-1 flex flex-col items-center px-4 py-8 gap-6">
    <div class="flex flex-col items-center gap-1 text-center">
      <h1 class="text-2xl font-bold text-secondary">Tu Certificado</h1>
      <p class="text-secondary/40 text-sm">Ingresa tu nombre para personalizar el certificado</p>
    </div>

    <!-- Name input — placeholder until login integration -->
    <input
      id="cert-name"
      type="text"
      placeholder="Tu nombre completo"
      maxlength="60"
      data-track-title={track.title}
      class="w-full max-w-sm px-4 py-2.5 rounded-lg bg-light-bg border border-stroke-color text-secondary placeholder:text-secondary/30 focus:outline-none focus:border-yellow transition-colors text-center font-medium"
    />

    <!-- 2-col on desktop: donation | certificate -->
    <div class="w-full max-w-5xl flex flex-col lg:flex-row gap-6 items-start">

      <!-- Left: Donation box -->
      <div class="w-full lg:flex-1 border border-stroke-color backdrop-blur-md bg-bg-nav rounded-md shadow-lg p-6 flex flex-col sm:flex-row lg:flex-col gap-6">
        <div class="flex flex-col gap-3 flex-1 text-sm leading-relaxed text-secondary/80">
          <p>
            Solo tú puedes ver este mensaje.
            <strong class="text-secondary">Felicidades por completar esta certificación — no fue fácil, y eso vale mucho.</strong>
          </p>
          <p>
            Rustlings Web es un proyecto completamente gratuito para la comunidad hispanohablante de Rust.
            Cada lección, cada ejercicio y cada mejora de la plataforma es construida con tiempo y dedicación
            por personas que creen que el conocimiento debe ser accesible para todos, sin importar el idioma.
          </p>
          <p>
            Tu apoyo nos motiva a seguir añadiendo nuevos temas, mejorar los ejercicios existentes
            y expandir la plataforma para que más personas en el mundo de habla hispana
            puedan dar sus primeros pasos en Rust — o ir mucho más allá.
          </p>
          <p class="text-secondary/50">
            Cada contribución, por pequeña que sea, nos ayuda a mantener las luces encendidas
            y los servidores corriendo. Gracias por ser parte de esta comunidad. 🦀
          </p>
        </div>

        <div class="flex flex-col gap-3 shrink-0 sm:w-56 lg:w-full">
          <div class="grid grid-cols-2 border border-stroke-color rounded-lg overflow-hidden">
            <button
              id="toggle-monthly"
              class="py-1.5 text-xs font-semibold bg-[#222222] text-white transition-colors"
            >
              Mensual
            </button>
            <button
              id="toggle-once"
              class="py-1.5 text-xs font-semibold text-secondary/60 hover:bg-light-bg transition-colors"
            >
              Única vez
            </button>
          </div>

          <p class="text-secondary/60 text-xs font-medium uppercase tracking-wide">
            Confirma tu donación<span id="frequency-label"> / mes</span>:
          </p>

          <div class="grid grid-cols-4 border border-stroke-color rounded-lg overflow-hidden">
            {[1, 5, 10, 20].map((amount) => (
              <button
                data-amount={amount}
                class:list={[
                  "donation-amount py-2 text-sm font-semibold transition-colors border-r border-stroke-color last:border-r-0",
                  amount === 10
                    ? "bg-[#FF6E1F] text-white"
                    : "text-secondary/60 hover:bg-light-bg",
                ]}
              >
                ${amount}
              </button>
            ))}
          </div>

          <p class="text-secondary/50 text-xs leading-relaxed">
            Tu donación de <span id="donation-selected-amount" class="text-secondary font-semibold">$10</span>
            <span id="hint-frequency"> al mes</span> ayuda a mantener Rustlings Web gratuito para todos.
          </p>

          <a
            id="donate-btn"
            href="https://github.com/sponsors/rustlang-es"
            target="_blank"
            rel="noopener noreferrer"
            class="w-full text-center rounded-lg bg-[#FF6E1F] py-2.5 font-semibold text-white hover:opacity-80 transition"
          >
            Donar $10 / mes
          </a>
        </div>
      </div>

      <!-- Right: Certificate -->
      <div class="w-full lg:flex-1 flex flex-col items-center gap-4">
        <!-- Shape variant selector -->
        <div class="flex gap-2">
          <button
            data-shape="hexagon"
            class="shape-btn flex flex-col items-center gap-1.5 px-5 py-3 rounded-xl border-2 border-[#FF6E1F] bg-[#FF6E1F]/10 text-secondary transition-all cursor-pointer"
          >
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
              <polygon points="14,2 25,8 25,20 14,26 3,20 3,8" stroke="#FF6E1F" stroke-width="2" fill="rgba(255,110,31,0.15)"/>
            </svg>
            <span class="text-xs font-semibold">Hexágono</span>
          </button>
          <button
            data-shape="triangle"
            class="shape-btn flex flex-col items-center gap-1.5 px-5 py-3 rounded-xl border-2 border-stroke-color text-secondary/50 transition-all cursor-pointer hover:border-[#FF6E1F]/50"
          >
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
              <polygon points="14,2 26,26 2,26" stroke="#FF6E1F" stroke-width="2" fill="rgba(255,110,31,0.15)"/>
            </svg>
            <span class="text-xs font-semibold">Triángulo</span>
          </button>
        </div>

        <div class="w-full max-w-md">
          <canvas
            id="certificate-canvas"
            width="600"
            height="600"
            class="w-full drop-shadow-2xl"
            data-logo-url={logoSvgUrl}
          ></canvas>
        </div>

        <button
          id="download-btn"
          class="flex items-center gap-2 rounded-lg bg-yellow px-8 py-3 font-semibold text-black hover:opacity-80 transition cursor-pointer"
        >
          Descargar PNG
        </button>
      </div>

    </div>
  </main>
</Layout>

<script>


  type Shape = "hexagon" | "triangle"

  function hexPath(ctx: CanvasRenderingContext2D, cx: number, cy: number, r: number) {
    ctx.beginPath()
    for (let i = 0; i < 6; i++) {
      const angle = (Math.PI / 3) * i - Math.PI / 2
      i === 0
        ? ctx.moveTo(cx + r * Math.cos(angle), cy + r * Math.sin(angle))
        : ctx.lineTo(cx + r * Math.cos(angle), cy + r * Math.sin(angle))
    }
    ctx.closePath()
  }

  function triPath(ctx: CanvasRenderingContext2D, cx: number, cy: number, r: number) {
    ctx.beginPath()
    for (let i = 0; i < 3; i++) {
      const angle = (Math.PI * 2 / 3) * i - Math.PI / 2
      i === 0
        ? ctx.moveTo(cx + r * Math.cos(angle), cy + r * Math.sin(angle))
        : ctx.lineTo(cx + r * Math.cos(angle), cy + r * Math.sin(angle))
    }
    ctx.closePath()
  }

  function shapePath(ctx: CanvasRenderingContext2D, shape: Shape, cx: number, cy: number, r: number) {
    shape === "hexagon" ? hexPath(ctx, cx, cy, r) : triPath(ctx, cx, cy, r)
  }

  async function drawCertificate(canvas: HTMLCanvasElement, trackTitle: string, name: string, shape: Shape = "hexagon", logoUrl = "") {
    const ctx = canvas.getContext("2d")!
    const W = canvas.width
    const H = canvas.height
    const cx = W / 2
    const cy = H / 2

    const ORANGE = "#FF6E1F"
    const LIGHT_GRAY = "#94a3b8"

    // Transparent background
    ctx.clearRect(0, 0, W, H)

    const R = 272
    const contentCy = cy

    // Per-shape layout offsets (triangle is narrower, so compress vertical spacing)
    const tri = shape === "triangle"
    const off = tri
      ? { icon: -130, title: -8, cert: 20, dots: 38, name: 64, date: 90, url: 118 }
      : { icon: -148, title: -18, cert: 18, dots: 40, name: 82, date: 112, url: 170 }

    // Outer glow layers
    for (let i = 3; i >= 1; i--) {
      shapePath(ctx, shape, cx, cy, R + i * 6)
      ctx.fillStyle = `rgba(255, 110, 31, ${0.06 * i})`
      ctx.fill()
    }

    // Background (dark gradient)
    shapePath(ctx, shape, cx, cy, R)
    ctx.save()
    ctx.clip()
    const grad = ctx.createLinearGradient(cx, cy - R, cx, cy + R)
    grad.addColorStop(0, "#1e1e2e")
    grad.addColorStop(1, "#0d0d18")
    ctx.fillStyle = grad
    ctx.fillRect(0, 0, W, H)
    ctx.restore()

    // Orange outer border
    shapePath(ctx, shape, cx, cy, R)
    ctx.strokeStyle = ORANGE
    ctx.lineWidth = 3
    ctx.stroke()

    // Subtle inner border
    shapePath(ctx, shape, cx, cy, R - 10)
    ctx.strokeStyle = "rgba(255, 110, 31, 0.25)"
    ctx.lineWidth = 1
    ctx.stroke()

    ctx.textAlign = "center"

    // Top icon - SVG logo
    const iconY = contentCy + off.icon
    const logoImg = new Image()
    await new Promise<void>((resolve) => {
      logoImg.onload = () => resolve()
      logoImg.onerror = () => resolve()
      logoImg.src = logoUrl
    })
    const logoW = 100
    const logoH = Math.round(logoW * (500.97 / 814.04))
    ctx.drawImage(logoImg, cx - logoW / 2, iconY - logoH / 2, logoW, logoH)

    // "RUSTLANG EN ESPAÑOL"
    ctx.fillStyle = ORANGE
    ctx.font = "600 13px 'Poppins', sans-serif"
    ctx.letterSpacing = "2px"
    ctx.fillText("RUSTLANG EN ESPAÑOL", cx, iconY + 68)
    ctx.letterSpacing = "0px"

    // Thin divider
    const divW = tri ? 70 : 90
    ctx.strokeStyle = "rgba(255,110,31,0.35)"
    ctx.lineWidth = 1
    ctx.beginPath()
    ctx.moveTo(cx - divW, iconY + 82)
    ctx.lineTo(cx + divW, iconY + 82)
    ctx.stroke()

    // Track title
    ctx.fillStyle = "#ffffff"
    ctx.font = "700 40px 'Poppins', sans-serif"
    const maxW = tri ? R * 1.1 : R * 1.4
    if (ctx.measureText(trackTitle).width > maxW) {
      const scaled = Math.floor(40 * (maxW / ctx.measureText(trackTitle).width))
      ctx.font = `700 ${scaled}px 'Poppins', sans-serif`
    }
    ctx.fillText(trackTitle, cx, contentCy + off.title)

    // "Certificación"
    ctx.fillStyle = ORANGE
    ctx.font = "600 17px 'Poppins', sans-serif"
    ctx.fillText("Certificación", cx, contentCy + off.cert)

    // Divider dots
    ctx.fillStyle = "rgba(255,110,31,0.4)"
    for (let i = -1; i <= 1; i++) {
      ctx.beginPath()
      ctx.arc(cx + i * 14, contentCy + off.dots, 2.5, 0, Math.PI * 2)
      ctx.fill()
    }

    // Name
    const displayName = name.trim() || "Tu Nombre"
    ctx.fillStyle = "#e2e8f0"
    ctx.font = "700 26px 'Poppins', sans-serif"
    const maxNameW = tri ? R * 1.6 : R * 1.5
    if (ctx.measureText(displayName).width > maxNameW) {
      const scaled = Math.floor(26 * (maxNameW / ctx.measureText(displayName).width))
      ctx.font = `700 ${scaled}px 'Poppins', sans-serif`
    }
    ctx.fillText(displayName, cx, contentCy + off.name)

    // Date
    const date = new Date().toLocaleDateString("es-MX", {
      year: "numeric",
      month: "short",
      day: "numeric",
    })
    ctx.fillStyle = LIGHT_GRAY
    ctx.font = "400 13px 'Poppins', sans-serif"
    ctx.fillText(date, cx, contentCy + off.date)

    // Bottom URL
    ctx.fillStyle = "rgba(148,163,184,0.5)"
    ctx.font = "400 11px 'Poppins', sans-serif"
    ctx.fillText("rustlings.rustlang-es.org", cx, contentCy + off.url)
  }

  document.addEventListener("astro:page-load", () => {
    const canvas = document.getElementById("certificate-canvas") as HTMLCanvasElement
    const nameInput = document.getElementById("cert-name") as HTMLInputElement
    const trackTitle = nameInput.dataset.trackTitle!
    const logoUrl = canvas.dataset.logoUrl!

    let currentShape: Shape = "hexagon"

    const redraw = () =>
      document.fonts.ready.then(() => drawCertificate(canvas, trackTitle, nameInput.value, currentShape, logoUrl))

    redraw()
    nameInput.addEventListener("input", redraw)

    // Shape variant selector
    document.querySelectorAll<HTMLButtonElement>(".shape-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        currentShape = btn.dataset.shape as Shape
        document.querySelectorAll<HTMLButtonElement>(".shape-btn").forEach((b) => {
          const active = b === btn
          b.classList.toggle("border-[#FF6E1F]", active)
          b.classList.toggle("bg-[#FF6E1F]/10", active)
          b.classList.toggle("text-secondary", active)
          b.classList.toggle("border-stroke-color", !active)
          b.classList.toggle("text-secondary/50", !active)
        })
        redraw()
      })
    })

    let selectedAmount = 10
    let isMonthly = true

    const donateBtn = document.getElementById("donate-btn") as HTMLAnchorElement
    const selectedAmountEl = document.getElementById("donation-selected-amount")
    const frequencyLabel = document.getElementById("frequency-label")
    const hintFrequency = document.getElementById("hint-frequency")
    const toggleMonthly = document.getElementById("toggle-monthly")!
    const toggleOnce = document.getElementById("toggle-once")!

    const updateDonateBtn = () => {
      const suffix = isMonthly ? " / mes" : " única vez"
      if (selectedAmountEl) selectedAmountEl.textContent = `$${selectedAmount}`
      if (frequencyLabel) frequencyLabel.textContent = isMonthly ? " / mes" : ""
      if (hintFrequency) hintFrequency.textContent = isMonthly ? " al mes" : ""
      if (donateBtn) {
        donateBtn.textContent = `Donar $${selectedAmount}${suffix}`
        donateBtn.href = `https://github.com/sponsors/rustlang-es?amount=${selectedAmount}`
      }
    }

    toggleMonthly.addEventListener("click", () => {
      isMonthly = true
      toggleMonthly.classList.replace("text-secondary/60", "text-white")
      toggleMonthly.classList.add("bg-[#222222]")
      toggleOnce.classList.remove("bg-[#222222]")
      toggleOnce.classList.replace("text-white", "text-secondary/60")
      updateDonateBtn()
    })

    toggleOnce.addEventListener("click", () => {
      isMonthly = false
      toggleOnce.classList.replace("text-secondary/60", "text-white")
      toggleOnce.classList.add("bg-[#222222]")
      toggleMonthly.classList.remove("bg-[#222222]")
      toggleMonthly.classList.replace("text-white", "text-secondary/60")
      updateDonateBtn()
    })

    document.querySelectorAll<HTMLButtonElement>(".donation-amount").forEach((btn) => {
      btn.addEventListener("click", () => {
        selectedAmount = Number(btn.dataset.amount)
        document.querySelectorAll<HTMLButtonElement>(".donation-amount").forEach((b) => {
          b.classList.toggle("bg-[#FF6E1F]", b === btn)
          b.classList.toggle("text-white", b === btn)
          b.classList.toggle("text-secondary/60", b !== btn)
        })
        updateDonateBtn()
      })
    })

    document.getElementById("download-btn")?.addEventListener("click", () => {
      const link = document.createElement("a")
      link.download = `certificado-${trackTitle.toLowerCase().replace(/\s+/g, "-")}.png`
      link.href = canvas.toDataURL("image/png")
      link.click()
    })
  })
</script>
