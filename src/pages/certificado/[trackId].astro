---
import logoSvgUrl from "~/assets/Rust_Lang_ES_Logo_Blanco_color.svg?url"
import { tracks } from "~/const/tracks"
import Layout from "~/layouts/Layout.astro"
import IconLeft from "~icons/tabler/arrow-big-left-lines-filled"

export const prerender = true

export function getStaticPaths() {
	return tracks
		.filter((t) => !t.disabled && t.slugs.length > 0)
		.map((t) => ({ params: { trackId: t.id }, props: { track: t } }))
}

const { track } = Astro.props
---

<Layout title={`Certificado — ${track.title}`}>
  <header class="p-2 w-full shrink-0">
    <nav class="relative z-50 flex items-center justify-between px-3 py-1 border border-stroke-color backdrop-blur-md bg-bg-nav rounded-md shadow-l
    ">
      <a
        href="/aprender"
        class="flex items-center gap-2 px-3 py-1.5 text-sm font-medium text-secondary/60 border border-transparent rounded-lg hover:border-yellow hover:text-yellow transition-all duration-300"
      >
        <IconLeft font-size={20} />
        Volver
      </a>
    </nav>
  </header>

  <main class="flex-1 flex flex-col items-center px-4 py-8 gap-6">
    <div class="flex flex-col items-center gap-1 text-center">
      <h1 class="text-2xl font-bold text-secondary">Tu Certificado</h1>
      <p class="text-secondary/40 text-sm" id="cert-subtitle">Cargando...</p>
    </div>

    <!-- Name display for logged-in users -->
    <div id="cert-name-display" class="hidden flex-col items-center gap-1">
      <p class="text-xl font-bold text-secondary" id="cert-name-text"></p>
      <a href="/perfil" class="inline-flex items-center gap-1 text-xs text-secondary/40 hover:text-yellow transition-colors">
        Editar nombre en perfil
        <span class="text-[10px]">→</span>
      </a>
    </div>

    <!-- Name input for anonymous users -->
    <input
      id="cert-name"
      type="text"
      placeholder="Tu nombre completo"
      maxlength="60"
      data-track-title={track.title}
      data-track-id={track.id}
      class="hidden w-full max-w-sm px-4 py-2.5 rounded-lg bg-light-bg border border-stroke-color text-secondary placeholder:text-secondary/30 focus:outline-none focus:border-yellow transition-colors text-center font-medium"
    />

    {/* Donation box removed — re-enable when needed */}

    <div class="w-full max-w-md flex flex-col items-center gap-4">
        <div class="w-full max-w-md">
          <canvas
            id="certificate-canvas"
            width="600"
            height="600"
            class="w-full drop-shadow-2xl"
            data-logo-url={logoSvgUrl}
          ></canvas>
        </div>

        <button
          id="download-btn"
          class="flex items-center gap-2 rounded-lg bg-yellow px-8 py-3 font-semibold text-black hover:opacity-80 transition cursor-pointer"
        >
          Descargar PNG
        </button>

        <!-- Share buttons (shown after cert is claimed) -->
        <div id="share-buttons" class="hidden flex-col items-center gap-3 w-full pt-2 border-t border-stroke-color/30">
          <p class="text-xs text-secondary/40">Comparte tu logro</p>
          <div class="flex gap-3 w-full">
            <a
              id="linkedin-btn"
              href="#"
              target="_blank"
              rel="noopener noreferrer"
              class="flex-1 flex items-center justify-center gap-2 py-2.5 text-sm font-semibold rounded-lg border border-stroke-color text-secondary/60 hover:border-[#0A66C2] hover:text-[#0A66C2] transition-all"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              LinkedIn
            </a>
            <a
              id="x-btn"
              href="#"
              target="_blank"
              rel="noopener noreferrer"
              class="flex-1 flex items-center justify-center gap-2 py-2.5 text-sm font-semibold rounded-lg border border-stroke-color text-secondary/60 hover:border-white hover:text-white transition-all"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.736-8.849L1.254 2.25H8.08l4.253 5.622L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
              </svg>
              Postear en X
            </a>
          </div>
        </div>
    </div>
  </main>
</Layout>

<script>


  function hexPath(ctx: CanvasRenderingContext2D, cx: number, cy: number, r: number) {
    ctx.beginPath()
    for (let i = 0; i < 6; i++) {
      const angle = (Math.PI / 3) * i - Math.PI / 2
      i === 0
        ? ctx.moveTo(cx + r * Math.cos(angle), cy + r * Math.sin(angle))
        : ctx.lineTo(cx + r * Math.cos(angle), cy + r * Math.sin(angle))
    }
    ctx.closePath()
  }

  async function drawCertificate(canvas: HTMLCanvasElement, trackTitle: string, name: string, logoUrl = "") {
    const ctx = canvas.getContext("2d")!
    const W = canvas.width
    const H = canvas.height
    const cx = W / 2
    const cy = H / 2

    const ORANGE = "#FF6E1F"
    const LIGHT_GRAY = "#94a3b8"

    ctx.clearRect(0, 0, W, H)

    const R = 272
    const off = { icon: -148, title: -18, cert: 18, dots: 40, name: 82, date: 112, url: 170 }

    // Outer glow layers
    for (let i = 3; i >= 1; i--) {
      hexPath(ctx, cx, cy, R + i * 6)
      ctx.fillStyle = `rgba(255, 110, 31, ${0.06 * i})`
      ctx.fill()
    }

    // Background (dark gradient)
    hexPath(ctx, cx, cy, R)
    ctx.save()
    ctx.clip()
    const grad = ctx.createLinearGradient(cx, cy - R, cx, cy + R)
    grad.addColorStop(0, "#1e1e2e")
    grad.addColorStop(1, "#0d0d18")
    ctx.fillStyle = grad
    ctx.fillRect(0, 0, W, H)
    ctx.restore()

    // Orange outer border
    hexPath(ctx, cx, cy, R)
    ctx.strokeStyle = ORANGE
    ctx.lineWidth = 3
    ctx.stroke()

    // Subtle inner border
    hexPath(ctx, cx, cy, R - 10)
    ctx.strokeStyle = "rgba(255, 110, 31, 0.25)"
    ctx.lineWidth = 1
    ctx.stroke()

    ctx.textAlign = "center"

    // Logo
    const iconY = cy + off.icon
    const logoImg = new Image()
    await new Promise<void>((resolve) => {
      logoImg.onload = () => resolve()
      logoImg.onerror = () => resolve()
      logoImg.src = logoUrl
    })
    const logoW = 140
    const logoH = Math.round(logoW * (500.97 / 814.04))
    ctx.drawImage(logoImg, cx - logoW / 2, iconY - logoH / 2, logoW, logoH)

    // "RUSTLANG EN ESPAÑOL"
    ctx.fillStyle = ORANGE
    ctx.font = "600 13px 'Poppins', sans-serif"
    ctx.letterSpacing = "2px"
    ctx.fillText("RUSTLANG EN ESPAÑOL", cx, iconY + 72)
    ctx.letterSpacing = "0px"

    // Thin divider
    ctx.strokeStyle = "rgba(255,110,31,0.35)"
    ctx.lineWidth = 1
    ctx.beginPath()
    ctx.moveTo(cx - 90, iconY + 86)
    ctx.lineTo(cx + 90, iconY + 86)
    ctx.stroke()

    // Track title
    ctx.fillStyle = "#ffffff"
    ctx.font = "700 40px 'Poppins', sans-serif"
    const maxW = R * 1.4
    if (ctx.measureText(trackTitle).width > maxW) {
      const scaled = Math.floor(40 * (maxW / ctx.measureText(trackTitle).width))
      ctx.font = `700 ${scaled}px 'Poppins', sans-serif`
    }
    ctx.fillText(trackTitle, cx, cy + off.title)

    // "Certificación"
    ctx.fillStyle = ORANGE
    ctx.font = "600 17px 'Poppins', sans-serif"
    ctx.fillText("Certificación", cx, cy + off.cert)

    // Divider dots
    ctx.fillStyle = "rgba(255,110,31,0.4)"
    for (let i = -1; i <= 1; i++) {
      ctx.beginPath()
      ctx.arc(cx + i * 14, cy + off.dots, 2.5, 0, Math.PI * 2)
      ctx.fill()
    }

    // Name
    const displayName = name.trim() || "Tu Nombre"
    ctx.fillStyle = "#e2e8f0"
    ctx.font = "700 26px 'Poppins', sans-serif"
    const maxNameW = R * 1.5
    if (ctx.measureText(displayName).width > maxNameW) {
      const scaled = Math.floor(26 * (maxNameW / ctx.measureText(displayName).width))
      ctx.font = `700 ${scaled}px 'Poppins', sans-serif`
    }
    ctx.fillText(displayName, cx, cy + off.name)

    // Date
    const date = new Date().toLocaleDateString("es-MX", {
      year: "numeric",
      month: "short",
      day: "numeric",
    })
    ctx.fillStyle = LIGHT_GRAY
    ctx.font = "400 13px 'Poppins', sans-serif"
    ctx.fillText(date, cx, cy + off.date)

    // Bottom URL
    ctx.fillStyle = "rgba(148,163,184,0.5)"
    ctx.font = "400 11px 'Poppins', sans-serif"
    ctx.fillText("rustlings.rustlang-es.org", cx, cy + off.url)
  }

  document.addEventListener("astro:page-load", async () => {
    const canvas = document.getElementById("certificate-canvas") as HTMLCanvasElement
    const nameInput = document.getElementById("cert-name") as HTMLInputElement
    const nameDisplay = document.getElementById("cert-name-display") as HTMLDivElement
    const nameText = document.getElementById("cert-name-text") as HTMLElement
    const subtitle = document.getElementById("cert-subtitle") as HTMLElement
    const trackTitle = nameInput.dataset.trackTitle!
    const trackId = nameInput.dataset.trackId!
    const logoUrl = canvas.dataset.logoUrl!

    let certName = ""

    const showShareButtons = (certId: string, issuedAt: string) => {
      const shareDiv = document.getElementById("share-buttons")!
      const linkedinBtn = document.getElementById("linkedin-btn") as HTMLAnchorElement
      const xBtn = document.getElementById("x-btn") as HTMLAnchorElement
      const certUrl = `${window.location.origin}/verificar/${certId}`
      const issued = new Date(issuedAt)

      const linkedinParams = new URLSearchParams({
        startTask: "CERTIFICATION_NAME",
        name: trackTitle,
        organizationId: "100302734", // RustLang ES LinkedIn page
        issueYear: String(issued.getFullYear()),
        issueMonth: String(issued.getMonth() + 1),
        certUrl,
        certId,
      })
      linkedinBtn.href = `https://www.linkedin.com/profile/add?${linkedinParams}`

      const xText = `¡Completé "${trackTitle}" en @rust_lang_es 🦀\nVer mi certificado: ${certUrl}`
      xBtn.href = `https://x.com/intent/post?text=${encodeURIComponent(xText)}`

      shareDiv.classList.remove("hidden")
      shareDiv.classList.add("flex")
    }

    // Try to load name from user profile
    try {
      const res = await fetch("/api/auth/me")
      if (res.ok) {
        const { fullName } = await res.json() as { fullName: string | null }
        if (fullName) {
          certName = fullName
          nameText.textContent = fullName
          nameDisplay.classList.remove("hidden")
          nameDisplay.classList.add("flex")
          subtitle.textContent = "Tu nombre se toma de tu perfil"

          // Auto-claim certificate and get certId for sharing
          fetch("/api/certificates/claim", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ courseId: trackId, nameUsed: fullName }),
          })
            .then((r) => r.json())
            // @ts-ignore
            .then(({ certId, issuedAt }: { certId?: string; issuedAt?: string }) => {
              if (certId && issuedAt) showShareButtons(certId, issuedAt)
            })
            .catch(() => {})
        } else {
          // Logged in but no full_name set
          nameDisplay.classList.remove("hidden")
          nameDisplay.classList.add("flex")
          nameText.textContent = "Sin nombre configurado"
          subtitle.textContent = "Configura tu nombre en tu perfil"
        }
      } else {
        // Not logged in — show input
        nameInput.classList.remove("hidden")
        subtitle.textContent = "Ingresa tu nombre para personalizar el certificado"
      }
    } catch {
      nameInput.classList.remove("hidden")
      subtitle.textContent = "Ingresa tu nombre para personalizar el certificado"
    }

    const getName = () => certName || nameInput.value

    const redraw = () =>
      document.fonts.ready.then(() => drawCertificate(canvas, trackTitle, getName(), logoUrl))

    redraw()
    nameInput.addEventListener("input", redraw)

    /* Donation logic removed — re-enable when needed */

    document.getElementById("download-btn")?.addEventListener("click", () => {
      const link = document.createElement("a")
      link.download = `certificado-${trackTitle.toLowerCase().replace(/\s+/g, "-")}.png`
      link.href = canvas.toDataURL("image/png")
      link.click()

      // Record certificate in DB for anonymous users (logged-in users already auto-claimed on load)
      const name = getName().trim()
      if (name && !certName) {
        fetch("/api/certificates/claim", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ courseId: trackId, nameUsed: name }),
        }).catch(() => {})
      }
    })
  })
</script>
