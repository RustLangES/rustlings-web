---
import Section from "~/components/sections/Section.astro"
import { getLangFromUrl, useTranslations } from "~/i18n/utils"
import IconBolt from "~icons/tabler/bolt"
import IconBrandRust from "~icons/tabler/brand-rust"
import IconCertificate from "~icons/tabler/certificate"
import IconDeviceLaptop from "~icons/tabler/device-laptop"
import IconLanguage from "~icons/tabler/language"
import IconProgress from "~icons/tabler/progress-check"
import IconUsers from "~icons/tabler/users"

interface Props {
	lang?: string
}

const { lang: langProp } = Astro.props
const lang = langProp ?? getLangFromUrl(Astro.url)
const t = useTranslations(lang)
---

<Section
  id="features"
  className="relative flex flex-col justify-center items-center w-full py-24 px-6 shrink-0"
>
  <div class="max-w-6xl w-full">

    <!-- Header -->
    <div class="text-center mb-14">
      <p class="text-yellow text-xs font-semibold tracking-widest uppercase mb-3">{t("features.why_choose")}</p>
      <h2 class="text-4xl md:text-5xl font-extrabold mb-4">
        {t("features.everything_you_need")}<br class="hidden md:block" /> {t("features.to_learn_rust")}
      </h2>
      <p class="text-secondary/45 text-base max-w-md mx-auto">
        {t("features.subtitle")}
      </p>
    </div>

    <!-- Bento grid -->
    <div id="bento-grid" class="grid grid-cols-1 md:grid-cols-3 gap-4">

      <!-- Card grande: Editor -->
      <div class="md:col-span-2 bento-card group relative overflow-hidden rounded-2xl border border-stroke-color bg-dark-fg p-8 flex flex-col gap-5 hover:border-yellow/30 transition-all duration-300">
        <div class="glow-yellow"></div>
        <div class="relative z-10">
          <span class="flex items-center justify-center w-11 h-11 rounded-xl bg-yellow/10 border border-yellow/20 mb-5">
            <IconDeviceLaptop font-size={22} class="text-yellow" />
          </span>
          <h3 class="text-xl font-bold mb-2">{t("features.integrated_editor")}</h3>
          <p class="text-secondary/50 text-sm leading-relaxed max-w-sm">
            {t("features.integrated_editor_desc")}
          </p>
        </div>
        <!-- mini mock editor -->
        <div class="relative z-10 rounded-xl overflow-hidden border border-stroke-color/60 bg-editor-bg font-mono text-xs leading-6 select-none">
          <div class="flex items-center gap-1.5 px-4 py-2 border-b border-stroke-color/60 bg-primary/30">
            <span class="w-2.5 h-2.5 rounded-full bg-[#ff5f57]"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-[#febc2e]"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-[#28c840]"></span>
            <span class="ml-2 text-secondary/20 text-[10px]">main.rs</span>
          </div>
          <div class="px-5 py-3">
            <div><span class="text-[#ff79c6]">fn</span> <span class="text-[#50fa7b]">main</span><span class="text-secondary/40">()</span> <span class="text-secondary/40">&lbrace;</span></div>
            <div class="pl-4"><span class="text-[#ff79c6]">println!</span><span class="text-secondary/40">(</span><span class="text-[#f1fa8c]">"{t("features.hello_rust")}"</span><span class="text-secondary/40">);</span></div>
            <div><span class="text-secondary/40">&rbrace;</span></div>
          </div>
          <div class="px-5 py-2 border-t border-stroke-color/60 text-[#28c840] text-[10px]">✓ {t("features.hello_rust")}</div>
        </div>
      </div>

      <!-- Card: Rust real -->
      <div class="bento-card group relative overflow-hidden rounded-2xl border border-stroke-color bg-dark-fg p-8 flex flex-col hover:border-yellow/30 transition-all duration-300">
        <div class="glow-yellow"></div>
        <div class="relative z-10 flex flex-col h-full">
          <span class="flex items-center justify-center w-11 h-11 rounded-xl bg-yellow/10 border border-yellow/20 mb-5">
            <IconBrandRust font-size={22} class="text-yellow" />
          </span>
          <h3 class="text-xl font-bold mb-2">{t("features.real_rust")}</h3>
          <p class="text-secondary/50 text-sm leading-relaxed flex-1">
            {t("features.real_rust_desc")}
          </p>
          <div class="mt-6 px-3 py-2 rounded-lg bg-primary/50 border border-stroke-color/50 font-mono text-xs text-[#ff5f57]">
            error[E0308]: mismatched types
          </div>
        </div>
      </div>

      <!-- Card: Español -->
      <div class="bento-card group relative overflow-hidden rounded-2xl border border-stroke-color bg-dark-fg p-8 flex flex-col hover:border-yellow/30 transition-all duration-300">
        <div class="glow-yellow"></div>
        <div class="relative z-10 flex flex-col h-full">
          <span class="flex items-center justify-center w-11 h-11 rounded-xl bg-yellow/10 border border-yellow/20 mb-5">
            <IconLanguage font-size={22} class="text-yellow" />
          </span>
          <h3 class="text-xl font-bold mb-2">{t("features.spanish_100")}</h3>
          <p class="text-secondary/50 text-sm leading-relaxed">
            {t("features.spanish_100_desc")}
          </p>
        </div>
      </div>

      <!-- Card: Progreso -->
      <div class="bento-card group relative overflow-hidden rounded-2xl border border-stroke-color bg-dark-fg p-8 flex flex-col hover:border-yellow/30 transition-all duration-300">
        <div class="glow-yellow"></div>
        <div class="relative z-10 flex flex-col h-full">
          <span class="flex items-center justify-center w-11 h-11 rounded-xl bg-yellow/10 border border-yellow/20 mb-5">
            <IconProgress font-size={22} class="text-yellow" />
          </span>
          <h3 class="text-xl font-bold mb-2">{t("features.saved_progress")}</h3>
          <p class="text-secondary/50 text-sm leading-relaxed flex-1">
            {t("features.saved_progress_desc")}
          </p>
          <!-- mini progress bar -->
          <div class="mt-6 space-y-2">
            {[
              { label: t("features.ownership"), pct: 100 },
              { label: t("features.borrowing"), pct: 70 },
              { label: t("features.structs"), pct: 30 },
            ].map(({ label, pct }) => (
              <div class="flex items-center gap-3 text-[10px]">
                <span class="text-secondary/40 w-16 shrink-0">{label}</span>
                <div class="flex-1 h-1 bg-stroke-color/50 rounded-full overflow-hidden">
                  <div class="h-full bg-yellow rounded-full" style={`width: ${pct}%`}></div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Card grande: Certificados + Comunidad -->
      <div class="md:col-span-1 bento-card group relative overflow-hidden rounded-2xl border border-stroke-color bg-dark-fg p-8 flex flex-col hover:border-yellow/30 transition-all duration-300">
        <div class="glow-yellow"></div>
        <div class="relative z-10 flex flex-col h-full gap-6">
          <div>
            <span class="flex items-center justify-center w-11 h-11 rounded-xl bg-yellow/10 border border-yellow/20 mb-5">
              <IconCertificate font-size={22} class="text-yellow" />
            </span>
            <h3 class="text-xl font-bold mb-2">{t("features.certificate_completion")}</h3>
            <p class="text-secondary/50 text-sm leading-relaxed">
              {t("features.certificate_completion_desc")}
            </p>
          </div>
          <div class="border-t border-stroke-color/40 pt-6">
            <span class="flex items-center justify-center w-11 h-11 rounded-xl bg-yellow/10 border border-yellow/20 mb-5">
              <IconUsers font-size={22} class="text-yellow" />
            </span>
            <h3 class="text-xl font-bold mb-2">{t("features.active_community")}</h3>
            <p class="text-secondary/50 text-sm leading-relaxed">
              {t("features.active_community_desc")}
            </p>
          </div>
        </div>
      </div>

      <!-- Card ancho: Velocidad -->
      <div class="md:col-span-2 bento-card group relative overflow-hidden rounded-2xl border border-stroke-color bg-dark-fg p-8 flex flex-col sm:flex-row items-center gap-8 hover:border-yellow/30 transition-all duration-300">
        <div class="glow-yellow"></div>
        <div class="relative z-10 shrink-0">
          <span class="flex items-center justify-center w-11 h-11 rounded-xl bg-yellow/10 border border-yellow/20 mb-5">
            <IconBolt font-size={22} class="text-yellow" />
          </span>
          <h3 class="text-xl font-bold mb-2">{t("features.instant_feedback")}</h3>
          <p class="text-secondary/50 text-sm leading-relaxed max-w-xs">
            {t("features.instant_feedback_desc")}
          </p>
        </div>
        <div class="relative z-10 flex-1 w-full">
          <div class="grid grid-cols-3 gap-2 text-center">
            {[
              { value: "39", label: t("features.exercises") },
              { value: "<1s", label: t("features.execution_time") },
              { value: "0", label: t("features.installations") },
            ].map(({ value, label }) => (
              <div class="py-4 rounded-xl bg-primary/50 border border-stroke-color/40">
                <p class="text-2xl font-extrabold text-yellow">{value}</p>
                <p class="text-secondary/40 text-[10px] mt-0.5">{label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>

    </div>
  </div>
</Section>

<style>
  #bento-grid:hover .glow-yellow {
    opacity: 0.4;
  }

  .bento-card:hover .glow-yellow {
    opacity: 1;
  }

  .glow-yellow {
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
    position: absolute;
    inset: 0;
    background: radial-gradient(
      600px circle at var(--mouse-x, 30%) var(--mouse-y, 20%),
      rgba(255, 215, 118, 0.12),
      transparent 40%
    );
    z-index: 1;
  }
</style>

<script>
  const grid = document.getElementById("bento-grid");

  grid?.addEventListener("mousemove", (e) => {
    const mouseEvent = e as MouseEvent;
    for (const card of grid.querySelectorAll<HTMLElement>(".bento-card")) {
      const rect = card.getBoundingClientRect();
      const x = mouseEvent.clientX - rect.left;
      const y = mouseEvent.clientY - rect.top;
      card.style.setProperty("--mouse-x", `${x}px`);
      card.style.setProperty("--mouse-y", `${y}px`);
    }
  });
</script>
