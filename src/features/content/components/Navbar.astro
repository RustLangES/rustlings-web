---
import logoImage from "~/assets/images/webp/logo.webp"
import Sidebar from "~/components/sidebar/Sidebar.astro"
import ToggleSidebarButton from "~/components/sidebar/ToggleSidebarButton.astro"
import { type Content, getLessonsByLang } from "~/content-manager"
import { getLangFromUrl } from "~/i18n/utils"
import IconBrandGithub from "~icons/tabler/brand-github"
import IconLogout from "~icons/tabler/logout"
import IconUser from "~icons/tabler/user"

interface Props {
	lang?: string
}
const { lang: langProp } = Astro.props
const lang = langProp ?? getLangFromUrl(Astro.url)
const user = Astro.locals.user
const lessons = getLessonsByLang(lang)

type GroupedLesson = { parent: Content; children: Content[] }

const groupMap = new Map<number, GroupedLesson>()

for (const lesson of lessons) {
	const { major, minor } = lesson.meta
	if (minor === 0) {
		groupMap.set(major, { parent: lesson, children: [] })
	} else {
		const group = groupMap.get(major)
		if (group) group.children.push(lesson)
	}
}

const sidebarItems = [...groupMap.values()].map(({ parent, children }) => ({
	label: `${parent.meta.major}. ${parent.meta.title}`,
	href: `/${lang}/${parent.meta.slug}`,
	children:
		children.length > 0
			? children.map((child) => ({
					label: `${parent.meta.major}.${child.meta.minor}. ${child.meta.title}`,
					href: `/${lang}/${child.meta.slug}`,
				}))
			: undefined,
}))
---

<header class="p-2 w-full">
  <nav
    class="relative z-50 flex items-center justify-between px-3 py-1 border border-stroke-color backdrop-blur-md bg-bg-nav rounded-md shadow-lg"
  >
    <div class="flex items-center gap-4">
      <ToggleSidebarButton sidebarId="content" label="Menú" />
    </div>

    <div class="flex items-center gap-2">
      <!-- DEBUG: remove before ship -->
      <button
        id="debug-tour-btn"
        class="hidden md:flex items-center gap-1 px-2 py-1 text-xs text-orange-400 border border-orange-400/30 rounded-md hover:bg-orange-400/10 transition-colors"
        title="[DEBUG] Lanzar tour"
      >
        tour
      </button>

      <a
        href="https://github.com/RustLangES/rustlings-web"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub Repository"
        class="hidden text-white md:flex gap-1 bg-editor-bg p-1 rounded-md border border-white/50 hover:scale-105 duration-300 justify-center items-center"
      >
        <IconBrandGithub font-size={20} />
      </a>

      {user ? (
        <div class="flex items-center gap-1">
          <a
            id="nav-profile-link"
            href="/perfil"
            class="flex items-center gap-1.5 px-2 py-1 text-xs text-secondary/60 rounded-md hover:text-yellow transition-colors"
          >
            <IconUser font-size={18} />
            <span class="hidden sm:inline">{user.username ?? user.email}</span>
          </a>
          <a
            href="/api/auth/logout"
            data-astro-reload
            title="Cerrar sesión"
            class="flex items-center gap-1 px-2 py-1 text-xs text-secondary/40 rounded-md hover:text-red-400 transition-colors"
          >
            <IconLogout font-size={14} />
          </a>
        </div>
      ) : (
        <a
          href="/login"
          class="flex items-center gap-1 px-2 py-1 text-xs text-secondary/50 rounded-md hover:text-yellow transition-colors"
          title="Iniciar sesión"
        >
          <IconUser font-size={18} />
        </a>
      )}
    </div>
  </nav>
</header>

<Sidebar
  id="content"
  items={sidebarItems}
  title="Contenido"
  position="left"
  logo={logoImage}
  backHref="/aprender"
  backLabel="Temario"
/>

<script>
  import { toast } from "~/utils/toasts"
  import { initAuthStore } from "~/lib/stores/auth-store"
  import { setupNavbar, onDisplayNameChange } from "~/lib/stores/user-utils"

  document.addEventListener("astro:page-load", () => {
    // Initialize auth store from server or fetch automatically
    initAuthStore()
    
    // Setup reactive navbar (this handles all user state changes automatically)
    setupNavbar({
      profileLinkId: "nav-profile-link",
      loginLinkId: null, // This navbar doesn't have a login link
      logoutLinkId: null // This navbar doesn't have a logout link directly
    })
    
    // Update username in profile link dynamically by targeting the span
    onDisplayNameChange((displayName) => {
      const profileLink = document.getElementById("nav-profile-link")
      const usernameSpan = profileLink?.querySelector("span")
      if (usernameSpan && displayName) {
        usernameSpan.textContent = displayName
      }
    })

    document.getElementById("debug-tour-btn")?.addEventListener("click", () => {
      const tracker = document.getElementById("lesson-tracker")
      const trackTitle = tracker?.dataset.trackTitle ?? "Fundamentos de Rust"

      toast.success(
        "¡Lo lograste! 🦀", 
        `Completaste ${trackTitle}. Encuentra tu certificado en tu perfil.`
      )
    })
  })
</script>
